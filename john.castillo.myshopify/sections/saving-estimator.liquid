<section class="benifit-wrapper">
  <div>
    <h2>{{ section.settings.heading }}</h2>
    <p>{{ section.settings.paragraph }}</p>
  </div>

  <div>
    <div>
      <div>
        <p>MONTHLY ELECTRICITY BILL</p>
        <p>$150</p>
      </div>
    </div>
  </div>
</section>

{% stylesheet %}
  .benifit-wrapper {
    padding-inline: 10px;
    padding-block: 30px;
  }

  .benefits-grid {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr 1fr;
    gap: 10px;
  }

  .benefit-item {
    padding: 10px;
    box-shadow: rgba(99, 99, 99, 0.2) 0px 2px 8px 0px;
    border-radius: 10px;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Hello World",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading"
    },
    {
      "type": "text",
      "id": "paragraph",
      "label": "Paragraph"
    }
  ],
  "presets": [
    {
      "name": "Hello World Template",
      "category": "Demo"
    }
  ]
}
{% endschema %}
