<div class="about-bamboo">
  <div class="about-bamboo__heading">
    {% if section.settings.header != blank %}
      <h2 class="about-bamboo__title">{{ section.settings.header }}</h2>
    {% endif %}
    {% if section.settings.paragraph != blank %}
      <p class="about-bamboo__subtitle">{{ section.settings.paragraph }}</p>
    {% endif %}
  </div>

  {% if section.blocks.size > 0 %}
    <div class="about-bamboo__grid">
      {% for block in section.blocks %}
        <div class="about-bamboo__card" {{ block.shopify_attributes }}>
          {% if block.settings.icon != blank %}
            <div class="about-bamboo__icon">
              <img
                src="{{ block.settings.icon | image_url: width: 80 }}"
                alt="{{ block.settings.title | escape }}"
                width="40"
                height="40"
                loading="lazy"
              >
            </div>
          {% else %}
            <div class="about-bamboo__icon about-bamboo__icon--placeholder">
              <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 2C8 2 5 5 5 9c0 5 7 13 7 13s7-8 7-13c0-4-3-7-7-7z"/><circle cx="12" cy="9" r="2.5"/></svg>
            </div>
          {% endif %}
          {% if block.settings.title != blank %}
            <h3 class="about-bamboo__card-title">{{ block.settings.title }}</h3>
          {% endif %}
          {% if block.settings.text != blank %}
            <p class="about-bamboo__card-text">{{ block.settings.text }}</p>
          {% endif %}
        </div>
      {% endfor %}
    </div>
  {% endif %}
</div>

{% stylesheet %}
  .about-bamboo {
    padding-block: 72px;
    padding-inline: var(--page-margin, 20px);
    max-width: var(--page-width, 90rem);
    margin-inline: auto;
    background-color: #f9f7f4;
  }

  .about-bamboo__heading {
    text-align: center;
    margin-bottom: 48px;
  }

  .about-bamboo__title {
    font-size: 32px;
    font-weight: 700;
    color: #1a1c19;
    margin-bottom: 10px;
  }

  .about-bamboo__subtitle {
    font-size: 15px;
    color: #6b7280;
    line-height: 1.6;
  }

  .about-bamboo__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 28px;
  }

  .about-bamboo__card {
    background: #ffffff;
    border-radius: 12px;
    padding: 32px 24px;
    border: 1px solid #e8e3dc;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .about-bamboo__icon {
    width: 48px;
    height: 48px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .about-bamboo__icon--placeholder {
    color: #7c572d;
  }

  .about-bamboo__card-title {
    font-size: 16px;
    font-weight: 700;
    color: #1a1c19;
  }

  .about-bamboo__card-text {
    font-size: 14px;
    color: #4b5563;
    line-height: 1.7;
  }

  @media (max-width: 900px) {
    .about-bamboo__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 600px) {
    .about-bamboo {
      padding-block: 48px;
    }

    .about-bamboo__grid {
      grid-template-columns: 1fr;
    }

    .about-bamboo__title {
      font-size: 24px;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Why Bamboo",
  "settings": [
    {
      "type": "text",
      "id": "header",
      "label": "Header"
    },
    {
      "type": "text",
      "id": "paragraph",
      "label": "Subtitle"
    }
  ],
  "blocks": [
    {
      "type": "feature",
      "name": "Feature",
      "settings": [
        {
          "type": "image_picker",
          "id": "icon",
          "label": "Icon"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Description"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Why Bamboo",
      "blocks": [
        {
          "type": "feature",
          "settings": {
            "title": "Rapidly Renewable",
            "text": "Bamboo grows up to 91 cm per day and is ready to harvest in 3–5 years — far faster than hardwood trees."
          }
        },
        {
          "type": "feature",
          "settings": {
            "title": "Carbon Negative",
            "text": "Bamboo absorbs more CO₂ and releases 35% more oxygen than an equivalent stand of trees."
          }
        },
        {
          "type": "feature",
          "settings": {
            "title": "Incredibly Strong",
            "text": "With a tensile strength rivaling steel, bamboo is lightweight yet durable for everyday use."
          }
        }
      ]
    }
  ],
  "disabled_on": {
    "groups": ["header", "footer"]
  }
}
{% endschema %}
