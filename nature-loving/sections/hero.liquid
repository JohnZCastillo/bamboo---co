<div
  class="hero-section full-width"
  {% if section.settings.background %}
    style="background-image: url('{{ section.settings.background | image_url: width: 1920 }}')"
  {% else %}
    style="background-image: url('{{ 'hero.png' | asset_url }}')"
  {% endif %}
>
  <div class="hero-inner">
    {% if section.settings.tagline != blank %}
      <p class="hero-tagline">{{ section.settings.tagline }}</p>
    {% endif %}

    {% if section.settings.header != blank %}
      <h1 class="hero-header">{{ section.settings.header }}</h1>
    {% endif %}

    {% if section.settings.paragraph != blank %}
      <p class="hero-paragraph">{{ section.settings.paragraph }}</p>
    {% endif %}

    <div class="hero-cta">
      <a
        href="{{ section.settings.primary_url | default: routes.all_products_collection_url }}"
        class="hero-btn hero-btn--primary"
      >
        {{ section.settings.primary_label | default: 'Shop Collection' }}
      </a>
    </div>
  </div>
</div>

{% stylesheet %}
  .hero-section {
    display: flex;
    align-items: center;
    justify-content: flex-start;
    min-height: 650px;
    padding-inline: 57px;
    background-repeat: no-repeat;
    background-position: center;
    background-size: cover;
  }

  .hero-inner {
    display: flex;
    flex-direction: column;
    gap: 20px;
    max-width: 560px;
  }

  .hero-tagline {
    display: inline-block;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    padding: 7px 14px;
    background-color: #c9e8c0;
    border-radius: 999px;
    color: #4f694a;
    width: max-content;
  }

  .hero-header {
    font-size: 48px;
    font-weight: 700;
    color: #1a1c19;
    line-height: 1.1;
  }

  .hero-paragraph {
    font-size: 15px;
    color: #4b5563;
    line-height: 1.7;
    max-width: 440px;
  }

  .hero-cta {
    display: flex;
    gap: 16px;
    flex-wrap: wrap;
    margin-top: 4px;
  }

  .hero-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 14px 28px;
    border-radius: 10px;
    font-size: 13px;
    font-weight: 700;
    letter-spacing: 0.05em;
    text-decoration: none;
    cursor: pointer;
    transition: background-color 0.2s, color 0.2s, border-color 0.2s;
  }

  .hero-btn--primary {
    background-color: #d4a574;
    color: #5b3a13;
    border: 2px solid transparent;
  }

  .hero-btn--primary:hover {
    background-color: #c4916a;
  }

  .hero-btn--secondary {
    background-color: transparent;
    color: #4a6546;
    border: 2px solid #4a6546;
  }

  .hero-btn--secondary:hover {
    background-color: #4a6546;
    color: #ffffff;
  }

  @media (max-width: 768px) {
    .hero-section {
      padding-inline: 24px;
      min-height: 500px;
    }

    .hero-header {
      font-size: 32px;
    }

    .hero-paragraph {
      font-size: 14px;
    }
  }

  @media (max-width: 480px) {
    .hero-cta {
      flex-direction: column;
    }

    .hero-btn {
      width: 100%;
      text-align: center;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Hero",
  "settings": [
    {
      "type": "text",
      "id": "header",
      "label": "Headline"
    },
    {
      "type": "text",
      "id": "tagline",
      "label": "Tagline badge"
    },
    {
      "type": "textarea",
      "id": "paragraph",
      "label": "Paragraph"
    },
    {
      "type": "text",
      "id": "primary_label",
      "label": "Primary button label",
      "default": "Shop Collection"
    },
    {
      "type": "url",
      "id": "primary_url",
      "label": "Primary button URL"
    },
    {
      "type": "text",
      "id": "secondary_label",
      "label": "Secondary button label",
      "default": "Our Process"
    },
    {
      "type": "url",
      "id": "secondary_url",
      "label": "Secondary button URL"
    },
    {
      "type": "image_picker",
      "id": "background",
      "label": "Background image"
    }
  ],
  "disabled_on": {
    "groups": ["header", "footer"]
  }
}
{% endschema %}
