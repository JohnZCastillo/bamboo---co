{% comment %}
  <pre>{{ product | json }}</pre>
  <script>
    console.log('Debug Product Object:', {{ collections['best-seller'].products | json }});
  </script>
{% endcomment %}

<div class="full-width container product-container">
  <div class="product-wrapper">
    <div class="product-header">
      <h2>{{ section.settings.header }}</h2>
      <a class="normal-link" href="{{ section.settings.product_list }}">{{ section.settings.tagline }}</a>
    </div>

    <div class="product-list">
      {% assign current_collection = section.settings.collection | default: collections['best-seller'] %}
      {% for product in current_collection.products %}
        <div
          class="product-item"
        >
          <img
            class="product-item-image"
            src="{{ product.featured_image | image_url: width: 600 }}"
            alt="{{ product.featured_image.alt | escape }}"
          >

          <h3 class="product-item-header">{{ product.title }}</h3>

          <div class="best">
            <p class="product-item-price">{{ product.price | money }}</p>
            <form action="/cart/add" method="post" id="product-form-{{ product.id }}">
              <input type="hidden" name="id" value="{{ product.variants.first.id }}">
              <div>
                <button type="submit" name="add">Add to cart</button>
              </div>
            </form>
          </div>
        </div>
      {% endfor %}
    </div>
  </div>
</div>

{% stylesheet %}
  .product-item-image {
    border-radius: 5px;
    margin-bottom: 10px;
    width: 300px;
    height: 300px;
    overflow: hidden;
  }

  .product-container {
    padding-block: 80px;
  }

  .product-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 48px;
  }

  .product-list {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr 1fr;
    gap: 20px;
  }

  .product-item {
    display: flex;
    flex-direction: column;
    align-items: start;
    justify-content: end;
    height: 300px;
    border-radius: 10px;
    background-repeat: no-repeat;
    background-size: cover;
    background-position: bottom;
  }

  .product-item-header {
    font-size: 18px;
    font-weight: 400;
    color: #1a1c19;
  }

  .product-item-price {
    font-size: 14px;
    color: #7c572d;
  }

  @media (max-width: 1100px) {
    .highlights {
      grid-template-columns: 1fr;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Best Seller",
  "settings": [
    {
      "type": "text",
      "id": "header",
      "label": "Header"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection"
    }
  ],
  "blocks": [
    {
      "name": "category",
      "type": "category",
      "settings": [
        {
          "type": "text",
          "id": "header",
          "label": "Header"
        },
        {
          "type": "number",
          "id": "price",
          "label": "Price"
        },
        {
          "type": "image_picker",
          "id": "background",
          "label": "Background"
        },
        {
          "type": "url",
          "id": "action",
          "label": "Action"
        }
      ]
    }
  ]
}
{% endschema %}
