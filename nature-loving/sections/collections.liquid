{% comment %}
  This section is used in the list-collections template to render a list of
  collections.

  https://shopify.dev/docs/storefronts/themes/architecture/templates/collection
{% endcomment %}

<div class="collections-page full-width container">
  <div class="collections-header">
    {% if section.settings.eyebrow != blank %}
      <p class="collections-header__eyebrow">{{ section.settings.eyebrow }}</p>
    {% endif %}
    {% if section.settings.heading != blank %}
      <h1 class="collections-header__heading">{{ section.settings.heading }}</h1>
    {% endif %}
    {% if section.settings.description != blank %}
      <p class="collections-header__description">{{ section.settings.description }}</p>
    {% endif %}
  </div>

  <div class="collections-grid">
    {% for collection in collections %}
      <a class="collection-card" href="{{ collection.url }}">
        <div class="collection-card__image-wrap">
          {% if collection.featured_image %}
            <img
              class="collection-card__image"
              src="{{ collection.featured_image | image_url: width: 900, height: 675, crop: 'center' }}"
              alt="{{ collection.featured_image.alt | default: collection.title | escape }}"
              width="900"
              height="675"
              loading="lazy"
            >
          {% else %}
            <div class="collection-card__image collection-card__image--placeholder"></div>
          {% endif %}
        </div>
        <div class="collection-card__overlay">
          <div class="collection-card__text">
            <h2 class="collection-card__title">{{ collection.title }}</h2>
            <span class="collection-card__cta">Shop Collection &rarr;</span>
          </div>
        </div>
      </a>
    {% endfor %}
  </div>
</div>

{% stylesheet %}
  .collections-page {
    padding-block: 60px;
  }

  /* ── Header ── */
  .collections-header {
    text-align: center;
    max-width: 600px;
    margin-inline: auto;
    margin-bottom: 48px;
  }

  .collections-header__eyebrow {
    font-size: 0.7rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--color-foreground);
    opacity: 0.6;
    margin-bottom: 12px;
  }

  .collections-header__heading {
    font-size: clamp(2rem, 4vw, 2.75rem);
    font-weight: 700;
    line-height: 1.2;
    margin-bottom: 20px;
    color: var(--color-foreground);
  }

  .collections-header__description {
    font-size: 0.9rem;
    line-height: 1.7;
    color: var(--color-foreground);
    opacity: 0.7;
  }

  /* ── Grid ── */
  .collections-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
  }

  /* ── Card ── */
  .collection-card {
    position: relative;
    display: block;
    border-radius: 12px;
    overflow: hidden;
    text-decoration: none;
    aspect-ratio: 4 / 3;
    background-color: #d9cfc4;
  }

  .collection-card__image-wrap {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
  }

  .collection-card__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.4s ease;
  }

  .collection-card__image--placeholder {
    width: 100%;
    height: 100%;
    background-color: #c9bfb3;
  }

  .collection-card:hover .collection-card__image {
    transform: scale(1.04);
  }

  /* dark gradient from bottom */
  .collection-card__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(0, 0, 0, 0.55) 0%, rgba(0, 0, 0, 0.15) 45%, transparent 70%);
    display: flex;
    align-items: flex-end;
  }

  .collection-card__text {
    padding: 20px 24px;
    color: #fff;
  }

  .collection-card__title {
    font-size: 1.25rem;
    font-weight: 600;
    margin-bottom: 4px;
    line-height: 1.2;
  }

  .collection-card__cta {
    font-size: 0.78rem;
    letter-spacing: 0.04em;
    opacity: 0.85;
  }

  /* ── Responsive ── */
  @media (max-width: 640px) {
    .collections-grid {
      grid-template-columns: 1fr;
    }

    .collections-page {
      padding-block: 40px;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Collections",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow Text",
      "default": "THE CURATED HOME"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Elevated Essentials for Conscious Living"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "Discover our thoughtfully assembled collections, where modern Asian minimalism meets sustainable craftsmanship. Each piece is selected to bring a sense of calm, order, and organic warmth to your daily rituals."
    }
  ],
  "presets": [{ "name": "Collections" }]
}
{% endschema %}
