{% comment %}
  This section is used in the product template to render product page with
  media, content, and add-to-cart form.

  https://shopify.dev/docs/storefronts/themes/architecture/templates/product
{% endcomment %}

{% assign current_variant = product.selected_or_first_available_variant %}

{%- comment -%}
  Pull review metafields — compatible with Shopify Product Reviews app,
  Judge.me, and any app that writes to the standard metafield namespace.
  Gracefully falls back to nothing if the metafields are absent.
{%- endcomment -%}
{% assign review_rating     = product.metafields.reviews.rating.value %}
{% assign review_count      = product.metafields.reviews.rating_count.value %}
{% assign review_rating_max = product.metafields.reviews.rating.value.scale_max | default: 5 %}

<div class="product-page">
  {%- comment -%} Breadcrumb {%- endcomment -%}
  <nav class="product-breadcrumb" aria-label="Breadcrumb">
    <a href="{{ routes.root_url }}">Home</a>
    {% if collection %}
      <span aria-hidden="true"> › </span>
      <a href="{{ collection.url }}">{{ collection.title }}</a>
    {% endif %}
    <span aria-hidden="true"> › </span>
    <span class="product-breadcrumb__current">{{ product.title }}</span>
  </nav>

  <div class="product-layout">
    {%- comment -%} ── Left: gallery ──────────────────────────── {%- endcomment -%}
    <div class="product-gallery">
      {%- comment -%} Thumbnails column {%- endcomment -%}
      <div class="product-gallery__thumbs" id="product-thumbs">
        {% for image in product.images limit: 5 %}
          <button
            class="product-gallery__thumb {% if forloop.first %}product-gallery__thumb--active{% endif %}"
            data-index="{{ forloop.index0 }}"
            aria-label="View image {{ forloop.index }}"
            type="button"
          >
            <img
              src="{{ image | image_url: width: 120, height: 120, crop: 'center' }}"
              alt="{{ image.alt | escape }}"
              width="120"
              height="120"
              loading="lazy"
            >
          </button>
        {% endfor %}
      </div>

      {%- comment -%} Main image {%- endcomment -%}
      <div class="product-gallery__main" id="product-main-image">
        {% for image in product.images limit: 5 %}
          <div
            class="product-gallery__slide {% if forloop.first %}product-gallery__slide--active{% endif %}"
            data-index="{{ forloop.index0 }}"
          >
            <img
              src="{{ image | image_url: width: 900, height: 900, crop: 'center' }}"
              alt="{{ image.alt | escape }}"
              width="900"
              height="900"
              {% if forloop.first %}
                loading="eager"
              {% else %}
                loading="lazy"
              {% endif %}
            >
          </div>
        {% endfor %}
        {% if product.images.size == 0 %}
          <div class="product-gallery__slide product-gallery__slide--active product-gallery__slide--placeholder">
            {{ 'product-1' | placeholder_svg_tag: 'product-gallery__placeholder-svg' }}
          </div>
        {% endif %}
      </div>
    </div>

    {%- comment -%} ── Right: product info ─────────────────────── {%- endcomment -%}
    <div class="product-info">
      <h1 class="product-info__title">{{ product.title }}</h1>



      <p class="product-info__price">{{ current_variant.price | money }}</p>

      {% if product.description != blank %}
        <div class="product-info__description">{{ product.description }}</div>
      {% endif %}

      {%- comment -%} Add-to-cart form {%- endcomment -%}
      {% form 'product', product, id: 'product-form', novalidate: true %}
        <input type="hidden" name="id" value="{{ current_variant.id }}" id="product-variant-id">

        <div class="product-info__purchase">
          {%- comment -%} Quantity stepper {%- endcomment -%}
          <div class="quantity-stepper" role="group" aria-label="Quantity">
            <button type="button" class="quantity-stepper__btn" id="qty-minus" aria-label="Decrease quantity">
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="14"
                height="14"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2.5"
                stroke-linecap="round"
              >
                <line x1="5" y1="12" x2="19" y2="12"/>
              </svg>
            </button>
            <input
              type="number"
              name="quantity"
              id="product-quantity"
              class="quantity-stepper__input"
              value="1"
              min="1"
              aria-label="Quantity"
            >
            <button type="button" class="quantity-stepper__btn" id="qty-plus" aria-label="Increase quantity">
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="14"
                height="14"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2.5"
                stroke-linecap="round"
              >
                <line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/>
              </svg>
            </button>
          </div>

          <button
            type="submit"
            name="add"
            class="product-info__add-btn"
            {% unless current_variant.available %}
              disabled
            {% endunless %}
          >
            {% if current_variant.available %}
              ADD TO CART
            {% else %}
              SOLD OUT
            {% endif %}
          </button>
        </div>


      {% endform %}

      {%- comment -%} Shipping / returns info box {%- endcomment -%}
      <div class="product-info__meta-box">
        <div class="meta-box-row">
          <span class="meta-box-row__icon" aria-hidden="true">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="18"
              height="18"
              viewBox="0 0 24 24"
              fill="none"
              stroke="#4a6546"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <rect x="1" y="3" width="15" height="13" rx="1"/><path d="M16 8h4l3 5v3h-7V8z"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/>
            </svg>
          </span>
          <div>
            <p class="meta-box-row__title">{{ section.settings.shipping_title | default: 'Shipping to Manila/NCR' }}</p>
            <p class="meta-box-row__text">
              {{ section.settings.shipping_text | default: 'Delivered in 2-3 business days.' }}
            </p>
          </div>
        </div>
        <div class="meta-box-row">
          <span class="meta-box-row__icon" aria-hidden="true">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="18"
              height="18"
              viewBox="0 0 24 24"
              fill="none"
              stroke="#4a6546"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/>
            </svg>
          </span>
          <div>
            <p class="meta-box-row__title">{{ section.settings.returns_title | default: 'Free Returns' }}</p>
            <p class="meta-box-row__text">
              {{ section.settings.returns_text | default: '30-day window for Metro Manila orders.' }}
            </p>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
  (function () {
    var thumbs = document.querySelectorAll('.product-gallery__thumb');
    var slides = document.querySelectorAll('.product-gallery__slide');

    thumbs.forEach(function (thumb) {
      thumb.addEventListener('click', function () {
        var idx = parseInt(this.dataset.index, 10);

        thumbs.forEach(function (t) {
          t.classList.remove('product-gallery__thumb--active');
        });
        slides.forEach(function (s) {
          s.classList.remove('product-gallery__slide--active');
        });

        this.classList.add('product-gallery__thumb--active');
        if (slides[idx]) slides[idx].classList.add('product-gallery__slide--active');
      });
    });

    var minus = document.getElementById('qty-minus');
    var plus = document.getElementById('qty-plus');
    var input = document.getElementById('product-quantity');

    if (minus && plus && input) {
      minus.addEventListener('click', function () {
        var v = parseInt(input.value, 10);
        if (v > 1) input.value = v - 1;
      });
      plus.addEventListener('click', function () {
        input.value = parseInt(input.value, 10) + 1;
      });
    }
  })();
</script>

{% stylesheet %}
  /* ── Page wrapper ─────────────────────────────────────────── */
  .product-page {
    padding-inline: 57px;
    padding-block: 32px 64px;
  }

  /* ── Breadcrumb ───────────────────────────────────────────── */
  .product-breadcrumb {
    font-size: 12px;
    color: #6b7280;
    margin-bottom: 24px;
  }

  .product-breadcrumb a {
    color: #6b7280;
    text-decoration: none;
  }

  .product-breadcrumb a:hover {
    text-decoration: underline;
  }

  .product-breadcrumb__current {
    color: #c8a96e;
    font-weight: 600;
  }

  /* ── Two-column layout ────────────────────────────────────── */
  .product-layout {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 64px;
    align-items: start;
  }

  /* ── Gallery ──────────────────────────────────────────────── */
  .product-gallery {
    display: grid;
    grid-template-columns: 72px 1fr;
    gap: 12px;
  }

  /* Thumbnails */
  .product-gallery__thumbs {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .product-gallery__thumb {
    width: 72px;
    height: 72px;
    border-radius: 8px;
    overflow: hidden;
    border: 2px solid transparent;
    padding: 0;
    background: #f3f4f0;
    cursor: pointer;
    transition: border-color 0.15s;
    flex-shrink: 0;
  }

  .product-gallery__thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .product-gallery__thumb--active {
    border-color: #4a6546;
  }

  .product-gallery__thumb:hover:not(.product-gallery__thumb--active) {
    border-color: #9ca3af;
  }

  /* Main image */
  .product-gallery__main {
    border-radius: 12px;
    overflow: hidden;
    background: #f3f4f0;
    aspect-ratio: 1 / 1;
    position: relative;
  }

  .product-gallery__slide {
    display: none;
    width: 100%;
    height: 100%;
  }

  .product-gallery__slide--active {
    display: block;
  }

  .product-gallery__slide img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .product-gallery__slide--placeholder {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 40px;
  }

  .product-gallery__placeholder-svg {
    width: 60%;
    height: 60%;
    color: #9ca3af;
  }

  /* ── Product info column ──────────────────────────────────── */
  .product-info__title {
    font-size: 28px;
    font-weight: 700;
    color: #1a1c19;
    margin-bottom: 8px;
    line-height: 1.25;
  }

  /* Price */
  .product-info__price {
    font-size: 22px;
    font-weight: 600;
    color: #c8a96e;
    margin-bottom: 20px;
  }

  /* Description */
  .product-info__description {
    font-size: 14px;
    color: #4b5563;
    line-height: 1.7;
    margin-bottom: 28px;
  }

  /* Purchase row */
  .product-info__purchase {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 16px;
  }

  /* Quantity stepper */
  .quantity-stepper {
    display: inline-flex;
    align-items: center;
    border: 1px solid #d1d5db;
    border-radius: 8px;
    overflow: hidden;
    height: 48px;
  }

  .quantity-stepper__btn {
    width: 42px;
    height: 100%;
    background: transparent;
    border: none;
    cursor: pointer;
    color: #374151;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background-color 0.15s;
    flex-shrink: 0;
  }

  .quantity-stepper__btn:hover {
    background-color: #f3f4f0;
  }

  .quantity-stepper__input {
    width: 44px;
    height: 100%;
    border: none;
    border-left: 1px solid #d1d5db;
    border-right: 1px solid #d1d5db;
    text-align: center;
    font-size: 15px;
    font-weight: 500;
    color: #1a1c19;
    background: transparent;
    -moz-appearance: textfield;
    appearance: textfield;
    outline: none;
    padding: 0;
    border-radius: 0;
  }

  .quantity-stepper__input::-webkit-outer-spin-button,
  .quantity-stepper__input::-webkit-inner-spin-button {
    -webkit-appearance: none;
    margin: 0;
  }

  /* Add to cart button */
  .product-info__add-btn {
    flex: 1;
    height: 48px;
    background-color: #7c572d;
    color: #ffffff;
    border: none;
    border-radius: 8px;
    font-size: 13px;
    font-weight: 700;
    letter-spacing: 0.08em;
    cursor: pointer;
    transition: background-color 0.2s;
  }

  .product-info__add-btn:hover:not(:disabled) {
    background-color: #6a4824;
  }

  .product-info__add-btn:disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }


  /* Shipping / returns info box */
  .product-info__meta-box {
    background-color: #f3f4f0;
    border-radius: 12px;
    padding: 20px 24px;
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .meta-box-row {
    display: flex;
    align-items: flex-start;
    gap: 12px;
  }

  .meta-box-row__icon {
    flex-shrink: 0;
    margin-top: 1px;
  }

  .meta-box-row__title {
    font-size: 13px;
    font-weight: 700;
    color: #1a1c19;
    margin-bottom: 2px;
  }

  .meta-box-row__text {
    font-size: 12px;
    color: #6b7280;
    line-height: 1.5;
  }

  /* ── Responsive ───────────────────────────────────────────── */
  @media (max-width: 900px) {
    .product-layout {
      grid-template-columns: 1fr;
      gap: 32px;
    }

    .product-gallery {
      grid-template-columns: 60px 1fr;
    }
  }

  @media (max-width: 640px) {
    .product-page {
      padding-inline: 16px;
    }

    .product-gallery {
      grid-template-columns: 1fr;
    }

    .product-gallery__thumbs {
      flex-direction: row;
      overflow-x: auto;
    }

    .product-gallery__thumb {
      width: 60px;
      height: 60px;
      flex-shrink: 0;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:general.product",
  "settings": [
    {
      "type": "text",
      "id": "shipping_title",
      "label": "Shipping title",
      "default": "Shipping to Manila/NCR"
    },
    {
      "type": "text",
      "id": "shipping_text",
      "label": "Shipping description",
      "default": "Delivered in 2-3 business days."
    },
    {
      "type": "text",
      "id": "returns_title",
      "label": "Returns title",
      "default": "Free Returns"
    },
    {
      "type": "text",
      "id": "returns_text",
      "label": "Returns description",
      "default": "30-day window for Metro Manila orders."
    }
  ],
  "disabled_on": {
    "groups": ["header", "footer"]
  }
}
{% endschema %}
